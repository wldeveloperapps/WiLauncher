rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /machines/{machineId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /audit_logs/{logId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
